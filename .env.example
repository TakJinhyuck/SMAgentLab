# ============================================================
# Ops-Navigator 환경 변수 예시
# 실제 사용 시 .env 로 복사하여 값을 채우세요
# cp .env.example .env
# ============================================================

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_DB=opsdb
POSTGRES_USER=ops
POSTGRES_PASSWORD=ops1234
DATABASE_URL=postgresql://ops:ops1234@postgres:5432/opsdb

# ── 임베딩 (Sentence-Transformers, 로컬 실행) ─────────────────
EMBEDDING_MODEL=paraphrase-multilingual-mpnet-base-v2
VECTOR_DIM=768

# ── LLM Provider 선택 ─────────────────────────────────────────
# "ollama"  : 로컬/내부망 Ollama 서버 사용 (기본값)
# "inhouse" : 사내 OpenAI 호환 LLM API 사용
LLM_PROVIDER=ollama

# ── Ollama 설정 (LLM_PROVIDER=ollama 시 사용) ─────────────────
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=exaone3.5:7.8b

# ── 사내 LLM 설정 (LLM_PROVIDER=inhouse 시 사용) ─────────────
# DevX MCP API
# INHOUSE_LLM_URL=https://devx-mcp-api.shinsegae-inc.com/api/v1/mcp-command/chat
# INHOUSE_LLM_API_KEY=Bearer 토큰 값
# INHOUSE_LLM_AGENT_CODE=playground
# INHOUSE_LLM_RESPONSE_MODE=streaming
# INHOUSE_LLM_TIMEOUT=120

# ── JWT 인증 ─────────────────────────────────────────────────
JWT_SECRET_KEY=change-this-secret-key-in-production
# ACCESS_TOKEN_EXPIRE_MINUTES=30
# REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Fernet 암호화 (사용자별 LLM API Key 암호화) ─────────────
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_SECRET_KEY=

# ── 초기 관리자 계정 ─────────────────────────────────────────
ADMIN_DEFAULT_PASSWORD=admin1234

# ── 검색 기본값 ───────────────────────────────────────────────
DEFAULT_TOP_K=5
DEFAULT_W_VECTOR=0.7
DEFAULT_W_KEYWORD=0.3

# ── Frontend → Backend 통신 ───────────────────────────────────
BACKEND_URL=http://backend:8000
